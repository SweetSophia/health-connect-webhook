<?xml version="1.0" encoding="utf-8"?>
<!--
   Network security configuration to prevent cleartext (HTTP) traffic.
   Health data should only be transmitted over encrypted HTTPS connections.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">100.111.85.48</domain>
    </domain-config>
</network-security-config>
