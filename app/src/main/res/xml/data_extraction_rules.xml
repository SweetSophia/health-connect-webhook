<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for API 31+.
   Excludes sensitive SharedPreferences containing webhook URLs and auth tokens.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="hc_webhook_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="hc_webhook_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>